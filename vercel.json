{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": "frontend",
      "framework": "vite",
      "routePrefix": "/"
    },
    "api": {
      "entrypoint": "app.py",
      "framework": "fastapi",
      "routePrefix": "/api",
      "maxDuration": 60,
      "includeFiles": "backend/**"
    }
  }
}
