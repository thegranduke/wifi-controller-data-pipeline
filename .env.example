# Used only when running WITHOUT Docker (see README → Running Locally).
# Docker Compose sets DATABASE_URL automatically — you do not need this file.

# Local Postgres connection string (create the database first, e.g. bconnect)
DATABASE_URL=postgresql://user:password@localhost:5432/bconnect

# Optional — live Gemini insights. Without this, POST /insights returns sample data.
GEMINI_API_KEY=
