# ── Docker (docker-compose up) ──────────────────────────────────────────────
# DATABASE_URL is set automatically by docker-compose. No action needed.

# ── Local dev (without Docker) ───────────────────────────────────────────────
# Option A — local Postgres:
# DATABASE_URL=postgresql://bconnect:bconnect@localhost:5432/bconnect
#
# Option B — Supabase (Session pooler URI from the Supabase dashboard):
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

DATABASE_URL=

# Google Gemini API key — required only for POST /insights (AI insights card).
# All other features (sync, sessions, history, charts) work without it.
GEMINI_API_KEY=
